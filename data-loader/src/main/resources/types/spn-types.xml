<CGR
  xsi:noNamespaceSchemaLocation="classpath:xsd/cgr.xsd"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <organization code="USACE">

    <type
      code="Creek"
      label="Creek"
      description="Creek"
      visibility="PUBLIC"
      geometryType="LINE"
      isGeometryEditable="true">
    </type>
    <type
      code="LandParcel"
      label="Land Parcel"
      description="Land Parcel"
      visibility="PUBLIC"
      geometryType="POLYGON"
      isGeometryEditable="true">
      <attributes>      
        <text
          code="landUse"
          label="Land Use"
          description="Land Use" />
        <text
          code="mailAddress"
          label="Mail Address"
          description="Mail Address" />          
        <decimal
          code="lotAcres"
          label="Lost Acres"
          description="Lot Acres"
          precision="10"
          scale="4" />          
<!--         
       <integer
         code="estimatedValue"
         label="Estimated Value"
         description="Estimated Value" />
 -->      
      </attributes>
      
    </type>
    
    <type
      code="FloodScenario"
      label="Flood scenario"
      description="Flood scenario"
      visibility="PUBLIC"
      geometryType="POLYGON"
      isGeometryEditable="true">
      <attributes>
        <text
          code="depth"
          label="Depth"
          description="Depth" />
        <text
          code="velocity"
          label="Velocity"
          description="Velocity" />
      </attributes>
    </type>

    <type
      code="Lake"
      label="Lake"
      description="Lake"
      visibility="PUBLIC"
      geometryType="POLYGON"
      isGeometryEditable="true">
    </type>


    <type
      code="Road"
      label="Road"
      description="Road"
      visibility="PUBLIC"
      geometryType="LINE"
      isGeometryEditable="true">
    </type>

    <type
      code="ComboPlanBridge"
      label="Combo Plan Bridge"
      description="Combo Plan Bridge"
      visibility="PUBLIC"
      geometryType="POLYGON"
      isGeometryEditable="true">
    </type>

    <type
      code="ComboPlanFloodwall"
      label="Combo Plan Floodwall"
      description="Combo Plan Floodwall"
      visibility="PUBLIC"
      geometryType="LINE"
      isGeometryEditable="true">
    </type>

    <type
      code="ComboPlanSlopeRepair"
      label="Combo Plan Slope Repair"
      description="Combo Plan Slope Repair"
      visibility="PUBLIC"
      geometryType="POLYGON"
      isGeometryEditable="true">
    </type>


    <type
      code="ComboPlanChannelFtprnt"
      label="Combo Plan Channel Widening Footprint"
      description="Combo Plan Channel Widening Footprint"
      visibility="PUBLIC"
      geometryType="POLYGON"
      isGeometryEditable="true">
    </type>

    <type
      code="ComboPlanPropGravel"
      label="Combo Plan Proposed Gravel Augmentation"
      description="Combo Plan Proposed Gravel Augmentation"
      visibility="PUBLIC"
      geometryType="POLYGON"
      isGeometryEditable="true">
    </type>

    <type
      code="ComboPlanPropRiprap"
      label="Combo Plan Proposed Riprap"
      description="Combo Plan Proposed Riprap"
      visibility="PUBLIC"
      geometryType="POLYGON"
      isGeometryEditable="true">
    </type>

    <type
      code="ProjectReach"
      label="Project Reach"
      description="Project Reach"
      visibility="PUBLIC"
      geometryType="POLYGON"
      isGeometryEditable="true">
    </type>

    <type
      code="ProjectArea"
      label="Project Area"
      description="Project Area"
      visibility="PUBLIC"
      geometryType="POLYGON"
      isGeometryEditable="true">
    </type>

    <type
      code="Structure"
      label="Structure"
      description="Structure"
      visibility="PUBLIC"
      geometryType="POINT"
      isGeometryEditable="true">
      <attributes>
        <text
          code="structureType"
          label="Structure Type"
          description="Structure Type" />
        <decimal
          code="valStruct"
          label="Value of Structure"
          description="Value of Structure"
          precision="10"
          scale="2" />          
        <decimal
          code="valContents"
          label="Value of Contents"
          description="Value of Contents"
          precision="10"
          scale="2" />                    
        <integer
          code="pop2amu65"
          label="Population under 65 (AM)"
          description="Population at night for the structure of people under the age of 65." />
        <integer
          code="pop2amo65"
          label="Population over 65 (AM)"
          description="Population at night for the structure of people over the age of 65." />
        <integer
          code="pop2pmu65"
          label="Population under 65 (PM)"
          description="Population during the day for the structure of people under the age of 65." />
        <integer
          code="pop2pmo65"
          label="Population over 65 (PM)"
          description="Population during the day for the structure of people over the age of 65." />

      </attributes>      
    </type>
