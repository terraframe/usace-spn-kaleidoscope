    <dag
      code="HasFloodRisk"
      label="Has Flood Risk"
      description="Edge denoting the location is at risk during the attached flood scenario" />

    <dag
      code="FlowsInto"
      label="Flows Into"
      description="Edge denoting a water location flows into another water location" />

    <dag
      code="LocatedIn"
      label="Located In"
      description="Edge denoting one location is within another location" />

    <dag
      code="HasMitigation"
      label="Has Mitigation"
      description="Edge denoting the proposed mitigation changes associated with a scenario" />


  </organization>

</CGR>
